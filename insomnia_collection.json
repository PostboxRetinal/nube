{
  "info": {
    "_postman_id": "microservices-api-collection",
    "name": "Microservices API",
    "description": "API collection for testing microservices via HAProxy (variable-driven)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Users Service",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": "{{api_base_url}}/api/users"
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "url": "{{api_base_url}}/api/users/{{user_id}}"
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "url": "{{api_base_url}}/api/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"username\": \"johndoe\",\n  \"password\": \"password123\"\n}"
            },
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ]
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "url": "{{api_base_url}}/api/users/{{user_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Updated\",\n  \"email\": \"john.updated@example.com\",\n  \"username\": \"johnupdated\",\n  \"password\": \"newpassword123\"\n}"
            },
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ]
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "{{api_base_url}}/api/users/{{user_id}}"
          }
        }
      ]
    },
    {
      "name": "Products Service",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": "{{api_base_url}}/api/products"
          }
        },
        {
          "name": "Get Product By ID",
          "request": {
            "method": "GET",
            "url": "{{api_base_url}}/api/products/{{product_id}}"
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "url": "{{api_base_url}}/api/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Product\",\n  \"description\": \"A test product description\",\n  \"price\": 29.99,\n  \"stock\": 100\n}"
            },
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ]
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "url": "{{api_base_url}}/api/products/{{product_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Product\",\n  \"description\": \"Updated description\",\n  \"price\": 39.99,\n  \"stock\": 50\n}"
            },
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ]
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": "{{api_base_url}}/api/products/{{product_id}}"
          }
        }
      ]
    },
    {
      "name": "Orders Service",
      "item": [
        {
          "name": "Get All Orders",
          "request": {
            "method": "GET",
            "url": "{{api_base_url}}/api/orders"
          }
        },
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "url": "{{api_base_url}}/api/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": {{user_id}},\n  \"products\": [\n    {\n      \"id\": {{product_id}},\n      \"quantity\": 2\n    }\n  ]\n}"
            },
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ]
          }
        },
        {
          "name": "Delete Order",
          "request": {
            "method": "DELETE",
            "url": "{{api_base_url}}/api/orders/{{order_id}}"
          }
        }
      ]
    },
    {
      "name": "HAProxy",
      "item": [
        {
          "name": "HAProxy Stats",
          "request": {
            "method": "GET",
            "url": "{{haproxy_stats_url}}",
            "auth": {
              "type": "basic",
              "basic": [
                {"key": "username", "value": "{{haproxy_stats_user}}"},
                {"key": "password", "value": "{{haproxy_stats_password}}"}
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "api_base_url",
      "value": "http://127.0.0.1:18080"
    },
    {
      "key": "haproxy_stats_url",
      "value": "http://127.0.0.1:18081/stats"
    },
    {
      "key": "haproxy_stats_user",
      "value": "admin"
    },
    {
      "key": "haproxy_stats_password",
      "value": "haproxy_admin_2024"
    },
    {
      "key": "user_id",
      "value": "1"
    },
    {
      "key": "product_id",
      "value": "1"
    },
    {
      "key": "order_id",
      "value": ""
    }
  ]
}
