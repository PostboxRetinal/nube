          "request": {
            "method": "POST",
            "url": "http://192.168.124.20/api/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"username\": \"johndoe\",\n  \"password\": \"password123\"\n}"
            },
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ]
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "url": "http://192.168.124.20/api/users/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Updated\",\n  \"email\": \"john.updated@example.com\",\n  \"username\": \"johnupdated\",\n  \"password\": \"newpassword123\"\n}"
            },
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ]
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "http://192.168.124.20/api/users/1"
          }
        }
