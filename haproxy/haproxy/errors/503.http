HTTP/1.0 503 Service Unavailable
Cache-Control: no-cache
Connection: close
Content-Type: text/html

<!DOCTYPE html>
<html lang="es">
<head><title>Servicio no disponible</title></head>
<body style="margin:0;min-height:100vh;display:grid;place-items:center;padding:24px;font-family:'Trebuchet MS','Segoe UI',sans-serif;color:#1f2937;background:radial-gradient(circle at 20% 20%, #ffffff 0%, transparent 40%),radial-gradient(circle at 80% 10%, #dbeeff 0%, transparent 35%),linear-gradient(135deg,#f8fbff,#eaf4ff);">
  <main style="width:min(680px,100%);background:#ffffff;border:1px solid #e7eef7;border-radius:20px;padding:34px 30px;text-align:center;box-shadow:0 10px 30px rgba(31,41,55,0.1),0 0 0 6px rgba(15,108,189,0.18);">
    <span style="display:inline-block;padding:8px 14px;border-radius:999px;background:#d7e9ff;color:#0f6cbd;font-weight:700;font-size:0.9rem;letter-spacing:0.02em;">HAProxy Demo</span>
    <h1 style="margin:14px 0 8px;font-size:clamp(1.8rem,4.5vw,2.6rem);line-height:1.2;">Servicio temporalmente no disponible</h1>
    <p style="margin:0;color:#526072;font-size:1.05rem;">Todos los servidores estan fuera de servicio por el momento.</p>
    <p style="margin-top:18px;font-weight:700;color:#b42318;">Estado: 503 Service Unavailable</p>
  </main>
</body>
</html>
