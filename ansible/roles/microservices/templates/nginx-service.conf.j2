# =============================================================================
# Nginx Configuration for {{ service_name }} Service
# Generated by Ansible
# =============================================================================

server {
    listen 80;
    server_name localhost;

    # Health check endpoint
    location /health {
        access_log off;
        return 200 '{"status":"healthy","service":"{{ service_name }}"}';
        add_header Content-Type application/json;
    }

    # Root endpoint
    location / {
        return 200 '{"service":"{{ service_name }}","message":"Welcome to {{ service_name }} API","timestamp":"$time_iso8601","server":"$hostname"}';
        add_header Content-Type application/json;
    }

    # API endpoints for {{ service_name }}
    location /api/{{ service_name }}/ {
        return 200 '{"service":"{{ service_name }}","endpoint":"/api/{{ service_name }}/","method":"$request_method","timestamp":"$time_iso8601","server":"$hostname"}';
        add_header Content-Type application/json;
    }

    # Catch-all for any /api/ request
    location /api/ {
        return 200 '{"service":"{{ service_name }}","endpoint":"$uri","method":"$request_method","timestamp":"$time_iso8601","server":"$hostname"}';
        add_header Content-Type application/json;
    }
}