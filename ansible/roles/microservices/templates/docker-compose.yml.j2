# =============================================================================
# Docker Compose Configuration
# Generated by Ansible
# =============================================================================

networks:
  {{ docker_network_name }}:
    external: true

services:
  users_db:
    image: mysql:8.0
    container_name: users_db
    restart: always
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: users_db
      MYSQL_USER: app_users
      MYSQL_PASSWORD: app_password
    command: --default-authentication-plugin=mysql_native_password
    networks:
      - {{ docker_network_name }}
    healthcheck:
      test: ["CMD-SHELL", "mysqladmin ping -h localhost -uroot -proot || mysqladmin ping -h localhost -uroot"]
      interval: 10s
      timeout: 5s
      retries: 10

  products_db:
    image: mysql:8.0
    container_name: products_db
    restart: always
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: products_db
      MYSQL_USER: app_products
      MYSQL_PASSWORD: app_password
    command: --default-authentication-plugin=mysql_native_password
    networks:
      - {{ docker_network_name }}
    healthcheck:
      test: ["CMD-SHELL", "mysqladmin ping -h localhost -uroot -proot || mysqladmin ping -h localhost -uroot"]
      interval: 10s
      timeout: 5s
      retries: 10

  orders_db:
    image: mysql:8.0
    container_name: orders_db
    restart: always
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: orders_db
      MYSQL_USER: app_orders
      MYSQL_PASSWORD: app_password
    command: --default-authentication-plugin=mysql_native_password
    networks:
      - {{ docker_network_name }}
    healthcheck:
      test: ["CMD-SHELL", "mysqladmin ping -h localhost -uroot -proot || mysqladmin ping -h localhost -uroot"]
      interval: 10s
      timeout: 5s
      retries: 10

{% for service_key, service in microservices_config.items() %}
{% for instance in service.instances %}
  {{ instance.container_name }}:
    image: {{ service.image }}
    container_name: {{ instance.container_name }}
    restart: {{ service.restart_policy | default('always') }}
    ports:
      - "{{ instance.port }}:{{ instance.container_port | default(instance.port) }}"
    environment:
      SERVICE_NAME: "{{ service.name }}"
      SERVICE_PORT: "{{ instance.port }}"
      INSTANCE_ID: "{{ instance.container_name }}"
{% if service.environment is defined %}
{% for key, value in service.environment.items() %}
{% if key not in ['SERVICE_NAME', 'SERVICE_PORT', 'INSTANCE_ID'] %}
      {{ key }}: "{{ value }}"
{% endif %}
{% endfor %}
{% endif %}
{% if service.networks is defined %}
{% if service.networks is string %}
    networks:
      - {{ service.networks }}
{% else %}
    networks:
{% for network in service.networks %}
      - {{ network }}
{% endfor %}
{% endif %}
{% else %}
    networks:
      - {{ docker_network_name }}
{% endif %}
{% if service_key == 'users' %}
    depends_on:
      users_db:
        condition: service_healthy
{% elif service_key == 'products' %}
    depends_on:
      products_db:
        condition: service_healthy
{% elif service_key == 'orders' %}
    depends_on:
      orders_db:
        condition: service_healthy
{% endif %}
{% if service.healthcheck is defined %}
    healthcheck:
      test: {{ service.healthcheck.test | to_json }}
      interval: {{ service.healthcheck.interval }}
      timeout: {{ service.healthcheck.timeout }}
      retries: {{ service.healthcheck.retries }}
{% endif %}

{% endfor %}
{% endfor %}
