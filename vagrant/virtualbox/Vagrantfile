# -*- mode: ruby -*-
# vi: set ft=ruby :

# =============================================================================
# Vagrantfile for Control Node - VirtualBox on Windows 11
# =============================================================================

# Configuration Constants
BOX_NAME            = "generic/ubuntu2204"
VM_NAME             = "control-node"
VM_HOSTNAME         = "control-node"
VM_MEMORY           = 4096
VM_CPUS             = 2

# Network Configuration
CONTROL_NODE_IP     = "192.168.57.10"

# Paths
SCRIPTS_PATH        = "../scripts"
PROJECT_ROOT        = "../.."

Vagrant.configure("2") do |config|
  config.trigger.after :up do |trigger|
    trigger.name = "Auto-start nested VirtualBox VMs"
    trigger.run_remote = {
      inline: <<-SHELL
        if ! command -v VBoxManage >/dev/null 2>&1; then
          echo "VBoxManage not available yet, skipping nested VM autostart"
          exit 0
        fi

        for vm in vm-haproxy vm-microservices; do
          if VBoxManage showvminfo "$vm" >/dev/null 2>&1; then
            if VBoxManage list runningvms | grep -q "\"$vm\""; then
              echo "$vm already running"
            else
              echo "Starting $vm..."
              VBoxManage startvm "$vm" --type headless || true
            fi
          else
            echo "$vm not deployed yet (run ~/deploy-infrastructure.sh first)"
          fi
        done
      SHELL
    }
  end

  config.vm.define VM_NAME do |node|
    # Base box configuration
    node.vm.box      = BOX_NAME
    node.vm.hostname = VM_HOSTNAME

    # Network configuration for VirtualBox
    node.vm.network "private_network",
      ip: CONTROL_NODE_IP

    # Host-local access to nested HAProxy through control-node proxy
    node.vm.network "forwarded_port",
      guest: 80,
      host: 18080,
      host_ip: "127.0.0.1",
      auto_correct: true

    node.vm.network "forwarded_port",
      guest: 8080,
      host: 18081,
      host_ip: "127.0.0.1",
      auto_correct: true

    # Synced folders using VirtualBox shared folders (Windows compatible)
    node.vm.synced_folder "#{PROJECT_ROOT}/terraform", "/home/vagrant/terraform"
    node.vm.synced_folder "#{PROJECT_ROOT}/ansible", "/home/vagrant/ansible"
    node.vm.synced_folder "#{PROJECT_ROOT}/ssh-keys", "/home/vagrant/ssh-keys"

    # VirtualBox provider configuration
    node.vm.provider "virtualbox" do |vb|
      vb.name   = VM_NAME
      vb.memory = VM_MEMORY
      vb.cpus   = VM_CPUS

      # Performance optimizations
      vb.customize ["modifyvm", :id, "--natdnshostresolver1", "on"]
      vb.customize ["modifyvm", :id, "--natdnsproxy1", "on"]
      vb.customize ["modifyvm", :id, "--ioapic", "on"]
      vb.customize ["modifyvm", :id, "--paravirtprovider", "kvm"]
      vb.customize ["modifyvm", :id, "--nested-hw-virt", "on"]
      
      # Network adapter optimizations
      vb.customize ["modifyvm", :id, "--nictype1", "virtio"]
      vb.customize ["modifyvm", :id, "--nictype2", "virtio"]
      
      # Disable audio
      vb.customize ["modifyvm", :id, "--audio", "none"]
      
      # Disable USB
      vb.customize ["modifyvm", :id, "--usb", "off"]
      vb.customize ["modifyvm", :id, "--usbehci", "off"]
    end

    # Provisioning scripts (executed in order)
    node.vm.provision "generate-ssh-keys",
      type: "shell",
      path: "#{SCRIPTS_PATH}/generate-ssh-keys.sh",
      privileged: false

    node.vm.provision "install-packages",
      type: "shell",
      path: "#{SCRIPTS_PATH}/install-packages.sh",
      privileged: true,
      env: {
        "INFRA_PROVIDER" => "virtualbox"
      }

    node.vm.provision "install-terraform",
      type: "shell",
      path: "#{SCRIPTS_PATH}/install-terraform.sh",
      privileged: true

    node.vm.provision "install-ansible",
      type: "shell",
      path: "#{SCRIPTS_PATH}/install-ansible.sh",
      privileged: true

    node.vm.provision "setup-terraform-providers",
      type: "shell",
      path: "#{SCRIPTS_PATH}/setup-terraform-providers.sh",
      privileged: false,
      env: {
        "INFRA_PROVIDER" => "virtualbox"
      }

    node.vm.provision "configure-ansible",
      type: "shell",
      path: "#{SCRIPTS_PATH}/configure-ansible.sh",
      privileged: true

    node.vm.provision "create-helper-scripts",
      type: "shell",
      path: "#{SCRIPTS_PATH}/create-helper-scripts.sh",
      privileged: false,
      env: {
        "INFRA_PROVIDER" => "virtualbox",
        "CONTROL_NODE_IP" => CONTROL_NODE_IP
      }

    node.vm.provision "setup-nested-autostart",
      type: "shell",
      path: "#{SCRIPTS_PATH}/setup-nested-autostart.sh",
      privileged: true

    node.vm.provision "setup-host-proxy",
      type: "shell",
      path: "#{SCRIPTS_PATH}/setup-host-proxy.sh",
      privileged: true,
      env: {
        "INFRA_PROVIDER" => "virtualbox",
        "CONTROL_NODE_IP" => CONTROL_NODE_IP,
        "HAPROXY_IP" => "192.168.57.20",
        "PROXY_BIND_IP" => "0.0.0.0"
      }

    # Final message
    node.vm.post_up_message = <<-MESSAGE
    ============================================
    Control Node (VirtualBox) Ready!
    ============================================
    
    IP Address: #{CONTROL_NODE_IP}
    Provider:   VirtualBox
    
    To deploy infrastructure:
      vagrant ssh
      cd ~
      ./deploy-infrastructure.sh
    
    ============================================
    MESSAGE
  end
end